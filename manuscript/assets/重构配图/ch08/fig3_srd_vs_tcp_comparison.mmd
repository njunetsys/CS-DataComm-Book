%% 图3: SRD多路径 vs TCP单路径对比
%% 对比SRD(Scalable Reliable Datagram)和TCP的传输方式

flowchart TB
    subgraph Legend["📊 图例"]
        direction LR
        L1["🔵 数据包1"] 
        L2["🟢 数据包2"]
        L3["🟡 数据包3"]
        L4["🔴 数据包4"]
    end
    
    subgraph TCP["🐌 传统TCP单路径传输"]
        direction TB
        
        T1["发送端
        应用数据"]
        
        subgraph TCPPath["单一路径"]
            direction TB
            TP1["🔵🟢🟡🔴
            按序发送
            队列等待"]
            TP2["瓶颈链路
            带宽受限"]
            TP3["丢包!
            🟡丢失"]
            TP4["超时重传
            等待ACK"]
            TP5["Head-of-Line
        Blocking"]
        end
        
        T2["接收端
        按序交付"]
        
        T1 --> TP1 --> TP2 --> TP3 --> TP4 --> TP5 --> T2
    end
    
    subgraph SRD["⚡ SRD多路径传输"]
        direction TB
        
        S1["发送端
        应用数据"]
        
        subgraph SRDPaths["多路径并行"]
            direction LR
            
            subgraph Path1["路径1"]
                P1["🔵"]
            end
            
            subgraph Path2["路径2"]
                P2["🟢"]
            end
            
            subgraph Path3["路径3"]
                P3["🟡"]
            end
            
            subgraph Path4["路径4"]
                P4["🔴"]
            end
        end
        
        S2["接收端
        乱序重组"]
        
        S1 --> P1 & P2 & P3 & P4
        P1 & P2 & P3 & P4 --> S2
    end
    
    subgraph Comparison["📈 性能对比"]
        direction LR
        C1["TCP:
        • 单路径
        • 按序保证
        • HOL阻塞
        • 高延迟"]
        
        C2["SRD:
        • 多路径并行
        • 乱序交付
        • 微秒级重传
        • 低延迟"]
    end
    
    %% 样式定义
    classDef tcpStyle fill:#E74C3C,stroke:#C0392B,stroke-width:2px,color:#fff
    classDef srdStyle fill:#27AE60,stroke:#229954,stroke-width:2px,color:#fff
    classDef pathStyle fill:#3498DB,stroke:#2980B9,stroke-width:1px,color:#fff
    classDef packet1 fill:#4285F4,color:#fff
    classDef packet2 fill:#34A853,color:#fff
    classDef packet3 fill:#FBBC04,color:#000
    classDef packet4 fill:#EA4335,color:#fff
    classDef legendStyle fill:#F8F9FA,stroke:#DADCE0,stroke-width:1px,color:#000
    classDef compareStyle fill:#FFF8E1,stroke:#FFD54F,stroke-width:1px,color:#000
    
    class TCP,TCPPath,TP1,TP2,TP3,TP4,TP5,T1,T2 tcpStyle
    class SRD,SRDPaths,S1,S2 srdStyle
    class Path1,Path2,Path3,Path4,P1,P2,P3,P4 pathStyle
    class C1 tcpStyle
    class C2 srdStyle
    class Legend,L1,L2,L3,L4 legendStyle
    class Comparison compareStyle
