graph TB
    subgraph "Nitro System"
        subgraph "Nitro Cards"
            NC1[Nitro Network Card<br/>ENA/SRD协议处理<br/>加密/压缩卸载]
            NC2[Nitro Storage Card<br/>EBS数据面<br/>NVMe控制器]
            NC3[Nitro Security Chip<br/>TPM/HSM<br/>硬件根信任]
        end
        
        NH[Nitro Hypervisor<br/>轻量级虚拟化<br/>KVM优化]
        
        subgraph "Host"
            VM1[客户VM]
            VM2[客户VM]
        end
    end
    
    subgraph "External"
        VPC[VPC网络]
        EBS[EBS存储]
        KMS[AWS KMS]
    end
    
    VM1 -.->|"虚拟设备"| NH
    VM2 -.->|"虚拟设备"| NH
    NH -->|"SR-IOV"| NC1
    NH -->|"NVMe"| NC2
    NC1 --> VPC
    NC2 --> EBS
    NC3 --> KMS
    
    style NC1 fill:#e1f5fe
    style NC2 fill:#e8f5e9
    style NC3 fill:#fff3e0
    style NH fill:#fce4ec